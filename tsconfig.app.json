{
  "extends": "../../.nuxt/tsconfig.app.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo.app",
    "noEmit": true
  },
  "include": [
    "../../.nuxt/imports.d.ts",
    "../../.nuxt/components.d.ts",
    "../../.nuxt/types/imports.d.ts",
    "../../.nuxt/types/components.d.ts",
    "../../.nuxt/types/layouts.d.ts",
    "../../.nuxt/types/middleware.d.ts",
    "../../.nuxt/types/plugins.d.ts",
    "../../.nuxt/types/typed-router.d.ts",
    "./app/**/*",
    "./shared/**/*",
    "./modules/**/*",
    "./config.ts",
    "./exposed.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    "./server/**/*"
  ]
}
